{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "git": {
    "deploymentEnabled": true
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.shoprealscents.com"
        }
      ],
      "destination": "https://shoprealscents.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/google-merchant-feed.xml",
      "destination": "/api/google-merchant-feed"
    }
  ]
}
